# Copy to .env and fill in your key
# xAI (Grok) API key
XAI_API_KEY=

# Optional: override if xAI changes endpoints
XAI_BASE_URL=https://api.x.ai/v1

# Optional: model id for chat completions.
# If unset (recommended), the agent will try a default and auto-fallback if it's not available.
GROK_MODEL=

# Photon / Spectrum credentials (Project Settings in the Photon dashboard)
PROJECT_ID=

# Photon docs may call this SECRET_KEY; this repo supports either.
PROJECT_SECRET=
SECRET_KEY=

# ZeroMQ PUB endpoint from cpp_engine (default tcp://127.0.0.1:5555)
ZMQ_ENDPOINT=
