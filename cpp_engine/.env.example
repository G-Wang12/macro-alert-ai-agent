# Copy to .env and fill in your key
# Finnhub API key (required only for --live mode; --simulate ignores it).
# Get one at https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ZeroMQ endpoint the engine SUBSCRIBES to for filter-set updates pushed by the
# agent (the union of all users' tracked keywords + watchlist tickers). When set,
# the engine narrows what it forwards to that set; with no agent connected it
# keeps its built-in macro keyword filter. Must match the agent's FILTER_ENDPOINT.
# Default tcp://127.0.0.1:5556
FILTER_ENDPOINT=
